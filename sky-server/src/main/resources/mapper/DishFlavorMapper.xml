<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.sky.mapper.DishFlavorMapper">

    <insert id="insert" >
        insert into dish_flavor (dish_id, name, value) value
        <foreach collection="flavors" item="item" index="index" separator=",">
            (#{item.dishId}, #{item.name}, #{item.value})
        </foreach>
    </insert>
    <delete id="deleteByDishIds">
        delete from dish_flavor where dish_id in
        <foreach collection="dishIdList" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
    <select id="selectByDishId" resultType="com.sky.entity.DishFlavor">
        select * from dish_flavor where dish_id = #{dishId}
    </select>
</mapper>